NEXT_PUBLIC_SUPABASE_PROJECT_ID=jxumcqmagdwyvsanmauw
NEXT_PUBLIC_SUPABASE_URL=https://jxumcqmagdwyvsanmauw.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
NEXT_PUBLIC_SITE_URL=https://vitalrounds.com.au

# Server-only (Vercel + local): Settings → API → service_role — never expose to the browser
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
# Optional: private bucket used for wait list uploads
WAITLIST_STORAGE_BUCKET=waitlist-documents
# Optional: private bucket used for sales brochure PDFs
SALES_BROCHURES_BUCKET=sales-brochures
# Optional: private bucket used for applicant signup documents
APPLICANT_DOCUMENTS_BUCKET=applicant-documents
# Optional: base app URL used in auth/setup links from server jobs
APP_ORIGIN=https://vitalrounds.com.au
# Optional: wait list confirmation emails (Resend)
RESEND_API_KEY=your-resend-api-key-here
WAITLIST_FROM_EMAIL=VitalRounds <no-reply@vitalrounds.com.au>
WAITLIST_REPLY_TO=admin@vitalrounds.com.au
# Optional: comma-separated recipients for new wait list submission alerts
WAITLIST_ADMIN_NOTIFY_TO=admin@vitalrounds.com.au
# Optional: absolute URL for brand logo used in wait list emails
WAITLIST_EMAIL_LOGO_URL=https://vitalrounds.com.au/logo-original.png

# Optional: after login, send admins to the control subdomain
NEXT_PUBLIC_CONTROL_ORIGIN=https://control.vitalrounds.com.au

# Optional: share auth cookies across subdomains (set to .yourdomain.com in production). Required if users sign in on www and use control.yourdomain.com.
AUTH_COOKIE_DOMAIN=.vitalrounds.com.au

# Comma-separated emails allowed to open /control (omit to allow any user with role admin in metadata)
ADMIN_EMAILS=admin@vitalrounds.com.au
